# ─── Zoho OAuth (server-side only — never expose to the browser) ───
# Datacenter domains. US accounts use the .com domains below.
# EU: accounts.zoho.eu / people.zoho.eu  |  IN: accounts.zoho.in / people.zoho.in
# AU: accounts.zoho.com.au / people.zoho.com.au
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.com
ZOHO_PEOPLE_DOMAIN=https://people.zoho.com

# From the Self Client you create at https://api-console.zoho.com
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=

# Generated once via `npm run zoho:token` (see README). Long-lived.
ZOHO_REFRESH_TOKEN=

# ─── Leave type mapping ───
# Run `npm run zoho:leavetypes -- someone@byrdsonservices.com` to discover the
# numeric Leavetype IDs in your Zoho People account, then paste them here.
# These map the form's (holiday type + action) to real Zoho leave types.

# --- Regular Holiday view ---
ZOHO_LEAVETYPE_HOLIDAY=
ZOHO_LEAVETYPE_HOLIDAY_CREDIT=
ZOHO_LEAVETYPE_WORKED_HOLIDAY=

# --- Special Non-Working Holiday view ---
ZOHO_LEAVETYPE_SPECIAL_HOLIDAY=
ZOHO_LEAVETYPE_SPECIAL_HOLIDAY_CREDIT=
ZOHO_LEAVETYPE_SPECIAL_WORKED_HOLIDAY=

# Optional: the Zoho leave form's link name (default "leave") and the field
# name used for the reason/notes (varies per account; common: "Reasonforleave").
ZOHO_LEAVE_FORM_LINKNAME=leave
ZOHO_LEAVE_REASON_FIELD=Reasonforleave
