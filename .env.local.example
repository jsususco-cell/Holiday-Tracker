# ─── Zoho OAuth (server-side only — never expose to the browser) ───
# Datacenter domains. US accounts use the .com domains below.
# EU: accounts.zoho.eu / people.zoho.eu  |  IN: accounts.zoho.in / people.zoho.in
# AU: accounts.zoho.com.au / people.zoho.com.au
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.com
ZOHO_PEOPLE_DOMAIN=https://people.zoho.com

# From the Self Client you create at https://api-console.zoho.com
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=

# Generated once via `npm run zoho:token` (see README). Long-lived.
# Scope needed: ZohoPeople.forms.ALL,ZohoPeople.leave.ALL
ZOHO_REFRESH_TOKEN=

# Optional: searchable email field on your Zoho Employee form (default "EmailID").
ZOHO_EMP_EMAIL_FIELD=EmailID

# "Earn Holiday Credit" credits this leave type's balance (the "Holiday Leave
# Credits" type). Find the Id via `npm run zoho:leavetypes -- <employee-email>`.
ZOHO_LEAVETYPE_HOLIDAY_CREDIT_ID=
# Amount added per earned credit, in the leave type's unit (Hours). 8 = 1 day.
HOLIDAY_CREDIT_HOURS=8

# ─── Google Sheet receiver (Apps Script Web App) ───
# Deploy google-apps-script/Code.gs as a Web App, paste its URL here.
GOOGLE_SHEET_WEBHOOK_URL=
# Optional shared secret — must match the WEBHOOK_SECRET script property.
GOOGLE_SHEET_WEBHOOK_SECRET=
